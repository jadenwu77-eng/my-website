<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jaden Wu</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#000;color:#fff;overflow-x:hidden}

    header{
      position:fixed;top:0;width:100%;padding:16px 40px;
      background:rgba(0,0,0,0.6);
      backdrop-filter:blur(12px);
      z-index:1000;
      display:flex;justify-content:space-between
    }

    header div{font-weight:500}

    .section{
      position:relative;
      height:120vh;
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
      overflow:hidden;
      padding:0 20px;
    }

    .content{z-index:2;max-width:700px}

    h1{font-size:64px;font-weight:600;margin-bottom:20px}
    p{font-size:20px;color:#ccc}

    .parallax-img{
      position:absolute;top:0;left:0;
      width:100%;height:120%;
      background-size:cover;
      background-position:center;
      transform:translateY(0);
      z-index:1;opacity:0.5
    }

    .overlay{
      position:absolute;width:100%;height:100%;
      background:linear-gradient(to bottom, rgba(0,0,0,0.6), #000);
      z-index:1
    }

    .about{background:#111;padding:120px 20px;text-align:center}
    .about h2{font-size:40px;margin-bottom:20px}
    .about p{max-width:600px;margin:0 auto;color:#aaa}

    .contact{background:#000;padding:100px;text-align:center}
    .contact a{
      display:inline-block;margin-top:20px;
      padding:12px 24px;border:1px solid #fff;
      border-radius:999px;color:#fff;text-decoration:none
    }

    footer{text-align:center;padding:40px;color:#666}
  </style>
</head>
<body>

<header>
  <div>Jaden Wu</div>
</header>

<section class="section">
  <div class="parallax-img" style="background-image:url('https://images.unsplash.com/photo-1492724441997-5dc865305da7')"></div>
  <div class="overlay"></div>
  <div class="content">
    <h1>Hello, I'm Jaden</h1>
    <p>I build ideas, brands, and digital experiences.</p>
  </div>
</section>

<section class="section">
  <div class="parallax-img" style="background-image:url('https://images.unsplash.com/photo-1506744038136-46273834b3fb')"></div>
  <div class="overlay"></div>
  <div class="content">
    <h1>What I Do</h1>
    <p>Content strategy, storytelling, and creative direction.</p>
  </div>
</section>

<section class="about">
  <h2>About Me</h2>
  <p>
    I'm passionate about building meaningful projects and telling stories that connect people.
    Currently focused on content creation, branding, and exploring digital opportunities.
  </p>
</section>

<section class="contact">
  <h2>Contact Me</h2>
  <p>Let's work together.</p>
  <a href="#">Get in touch</a>
</section>

<footer>
  <p>© 2026 Jaden Wu</p>
</footer>

<script>
  const sections = document.querySelectorAll('.section');

  window.addEventListener('scroll', () => {
    sections.forEach(section => {
      const img = section.querySelector('.parallax-img');
      if(!img) return;
      const speed = 0.3;
      const offset = window.scrollY - section.offsetTop;
      img.style.transform = `translateY(${offset * speed}px)`;
    });
  });
</script>

</body>
</html>
